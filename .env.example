# --- API keys ---
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# --- agent ---
AGENT_NAME=Otto

# --- LLM ---
LLM_PROVIDER=openai          # openai | anthropic
LLM_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=

# --- Deepgram models ---
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-arcas-en
# Voice Agent (npm run converse) STT model. Flux gives model-level turn-taking.
STT_MODEL=flux-general-en
# Echo guard: pause feeding your mic to the Voice Agent while Otto speaks, so his
# voice from the speakers can't loop back and re-trigger him. true (speakers) /
# false (headphones — keeps full mid-sentence barge-in).
ECHO_GUARD=true

# --- Audio devices (names as shown by `npm run devices`) ---
# Your real microphone.
MIC_DEVICE=MacBook Air Microphone
# The cable that carries the call's INCOMING audio (system output is routed here).
CALL_CAPTURE_DEVICE=BlackHole 16ch
# The cable the call app uses as its MICROPHONE — your voice + Otto are written here
# (stereo, so use the 2-channel device).
CALL_MIC_DEVICE=BlackHole 2ch
# Where Otto's replies are also played so YOU hear them (your headphones/speakers).
MONITOR_DEVICE=MacBook Air Speakers
# Multi-output device created by `npm run setup` (your output + BlackHole 16ch).
ROUTE_DEVICE=Otto Monitor

# Mute your mic into the call while Otto is speaking, so Otto's audio from your
# speakers can't echo back into the call. true (recommended on speakers) / false (headphones).
DUCK_WHILE_SPEAKING=true
# When DUCK is false (headphones), barge-in is enabled: start talking and Otto
# stops. BARGE_RMS is the mic level (0..1) that counts as "talking" (raise if it
# triggers on background noise, lower if it's hard to interrupt).
BARGE_RMS=0.05

# Where transcripts/notes are saved.
NOTES_DIR=./notes

# Relay mode (Bluetooth): set the call app speaker to BlackHole 16ch; Otto transcribes
# the call AND plays it to your headphones (no Multi-Output needed). Adds ~200ms.
RELAY_CALL=false
